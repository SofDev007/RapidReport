# Copy this file to .env and fill in your values
SECRET_KEY=change-this-to-a-long-random-string

# Supabase connection string - Project Settings > Database > Connection string > Session pooler
# URL-encode special characters in the password (e.g. & -> %26, / -> %2F, ^ -> %5E)
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:5432/postgres

# Seeded on first startup if no user with this email exists yet.
# If ADMIN_PASSWORD is left unset, a random password is generated and printed once on startup.
ADMIN_EMAIL=admin@rapidreport.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
